{
  "name": "opencode-auto-force-resume",
  "version": "5.4.0",
  "description": "Intelligently detects and recovers stalled OpenCode sessions using abort+continue with status polling and progress tracking",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "stall-recovery",
    "session-recovery",
    "auto-recovery",
    "stuck-session",
    "abort",
    "continue"
  ],
  "license": "MIT",
  "author": "dracon",
  "homepage": "https://github.com/DraconDev/opencode-auto-force-resume",
  "repository": {
    "type": "git",
    "url": "https://github.com/DraconDev/opencode-auto-force-resume"
  },
  "bugs": {
    "url": "https://github.com/DraconDev/opencode-auto-force-resume/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.10",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "npm run build && cp src/index.ts ~/.config/opencode/plugins/opencode-auto-force-resume.ts && cp dist/index.js ~/.config/opencode/plugins/opencode-auto-force-resume.js && cp dist/index.d.ts ~/.config/opencode/plugins/opencode-auto-force-resume.d.ts",
    "prepublishOnly": "npm run build"
  }
}
